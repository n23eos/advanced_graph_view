{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"importHelpers": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts"]
}
